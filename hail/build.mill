    val natives = mvn"org.scalanlp::breeze-natives:1.1"
  }

  object Commons {
    val io = mvn"commons-io:commons-io:2.11.0"
    val lang3 = mvn"org.apache.commons:commons-lang3:3.12.0"
    val codec = mvn"commons-codec:commons-codec:1.15"
