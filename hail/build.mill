object Settings {
  val hailMajorMinorVersion = "0.2"
  val hailPatchVersion = "135"
  val scalaMinorVersions = Map("2.12" -> "2.12.20", "2.12.13" -> "2.12.13", "2.13" -> "2.13.13")
}

