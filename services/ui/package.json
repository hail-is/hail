{
  "name": "hail-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/ci/flaky_tests.tsx --bundle --jsx=automatic --format=esm --outdir=dist/ci --minify && esbuild src/batch/job.tsx --bundle --jsx=automatic --format=esm --outdir=dist/batch --minify",
    "check": "tsc --noEmit",
